# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=nordic
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=nordic_green

# ── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://nordic:your_password_here@postgres:5432/nordic_green
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h
FRONTEND_URL=http://localhost:3000
TOSS_SECRET_KEY=test_sk_your_toss_test_secret_key
TOSS_WEBHOOK_SECRET=your_webhook_secret_here

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_your_toss_test_client_key

# ── Google OAuth (선택 - 없으면 이메일 로그인만 가능) ─────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── 프로덕션 전용 ─────────────────────────────────────────────────────────────
# GITHUB_REPOSITORY_OWNER=your_github_username
