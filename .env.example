# ─── Shared ──────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-secret-here

# ─── Frontend (apps/frontend/.env.local) ─────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# PostgreSQL (used by NextAuth PrismaAdapter on the frontend)
DATABASE_URL=postgresql://user:password@localhost:5432/nordic_green

# ─── Backend (apps/backend/.env) ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/nordic_green

JWT_SECRET=your-jwt-secret   # Can reuse NEXTAUTH_SECRET
JWT_EXPIRES_IN=15m

FRONTEND_URL=http://localhost:3000
PORT=3001

# ─── Migration Script (MySQL source) ─────────────────────────────────────────
MYSQL_DATABASE_URL=mysql://user:password@localhost:3306/nordic_green_old
